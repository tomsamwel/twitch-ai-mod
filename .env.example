TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
# Optional: override broadcaster/bot login from config/app.yaml for the live bot.
# These only apply when running `npm run dev`; eval/replay scripts always use the YAML values.
TWITCH_BROADCASTER_LOGIN=your_channel_name
TWITCH_BOT_LOGIN=your_bot_account
TWITCH_REDIRECT_URI=http://localhost:3000/callback
TWITCH_OAUTH_HOST=localhost
TWITCH_OAUTH_PORT=3000
OPENAI_API_KEY=
APP_LOG_LEVEL=info
